# Copy this file to .env and fill in your values
JWT_SECRET=change-this-to-a-very-long-secret-key-min-32-chars!!

# Free tier – get from https://github.com/settings/tokens
GITHUB_TOKEN=

# Free tier – https://serper.dev
SERPER_API_KEY=

# Free tier – https://ai.google.dev
GEMINI_API_KEY=

# Optional paid – https://platform.openai.com
OPENAI_API_KEY=

# Twitter/X Developer Portal Bearer Token
TWITTER_BEARER_TOKEN=

# ProxyCurl for LinkedIn (paid) – https://nubela.co/proxycurl
PROXYCURL_API_KEY=

# Stack Exchange API key (optional – increases rate limit)
STACKOVERFLOW_KEY=
